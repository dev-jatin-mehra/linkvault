# Production Environment Variables
# Copy this to .env and fill in your production values

# Database (from your hosting provider - Railway, Render, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/linkvault

# Supabase project URL (used for JWT verification)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (required for secure account deletion)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend URL(s) allowed for CORS, comma-separated
# Example: https://your-frontend-domain.com,http://localhost:5173
CLIENT_URLS=http://localhost:5173

# Environment
NODE_ENV=development

# Port (usually set automatically by hosting platform)
# PORT=4000

